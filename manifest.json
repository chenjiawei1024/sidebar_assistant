{
  "manifest_version": 3,
  "name": "AI Sidebar",
  "version": "1.1.0",
  "description": "通用 AI 聊天侧边栏助手 - 支持 OpenAI 兼容接口",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*"
  ],
  "action": {
    "default_title": "打开 AI 侧边栏"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
